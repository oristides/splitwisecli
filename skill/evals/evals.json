{
  "skill_name": "splitwise-cli",
  "version": "1.2.0",
  "description": "Eval set for splitwise-cli. Both stages are fully deterministic — no LLM judge. Stage 1 checks skill triggering via JSON parse. Stage 2 checks CLI commands via flag tokenization.",
  "evals": [
    {
      "id": 1,
      "language": "en",
      "type": "single-call",
      "prompt": "List all my friends and their balances.",
      "expected_calls": [
        {
          "command": "splitwisecli friend list",
          "required_flags": [],
          "forbidden_flags": []
        }
      ]
    },
    {
      "id": 2,
      "language": "en",
      "type": "single-call",
      "prompt": "I paid $85 for dinner last night with my friend (ID 456). Split it equally.",
      "expected_calls": [
        {
          "command": "splitwisecli expense create --friend 456 -d \"Dinner\" -c 85",
          "required_flags": ["--friend 456", "-c 85|--cost 85"],
          "forbidden_flags": ["--paid-by friend", "--paid-by 456"]
        }
      ]
    },
    {
      "id": 3,
      "language": "pt",
      "type": "single-call",
      "prompt": "Minha amiga (ID 789) pagou R$120 no almoço. Quero dividir igualmente.",
      "expected_calls": [
        {
          "command": "splitwisecli expense create --friend 789 -d \"Almoço\" -c 120 --paid-by friend",
          "required_flags": ["--friend 789", "-c 120|--cost 120", "--paid-by friend"],
          "forbidden_flags": ["--paid-by me"]
        }
      ]
    },
    {
      "id": 4,
      "language": "en",
      "type": "single-call",
      "prompt": "I covered a $200 grocery run for friend ID 321. They owe me the full amount.",
      "expected_calls": [
        {
          "command": "splitwisecli expense create --friend 321 -d \"Groceries\" -c 200 --split 0,100",
          "required_flags": ["--friend 321", "-c 200|--cost 200", "--split 0,100"],
          "forbidden_flags": ["--paid-by friend", "--split 50,50", "--equal"]
        }
      ]
    },
    {
      "id": 5,
      "language": "pt",
      "type": "single-call",
      "prompt": "Quanto eu devo pra cada amigo? Quero ver todos os saldos.",
      "expected_calls": [
        {
          "command": "splitwisecli balance",
          "required_flags": [],
          "forbidden_flags": ["--friend", "--group"]
